# ─── Model provider ──────────────────────────────────────────────────────────
# Choose one of: local | openrouter | opencode
# - local:       vLLM runs inside the container (default)
# - openrouter:  use OpenRouter (https://openrouter.ai) — requires ENABLE_VLLM=0
# - opencode:    use OpenCode Zen (https://opencode.ai) — requires ENABLE_VLLM=0
MODEL_PROVIDER=local

# ─── OpenRouter ──────────────────────────────────────────────────────────────
# Required when MODEL_PROVIDER=openrouter
# Note: vLLM is automatically disabled when MODEL_PROVIDER=openrouter or opencode
OPENROUTER_API_KEY=sk-or-v1-...
# Model ID as listed on openrouter.ai/models  (e.g. openai/gpt-4o, anthropic/claude-3.5-sonnet)
OPENROUTER_MODEL=openai/gpt-4o

# ─── OpenCode Zen ────────────────────────────────────────────────────────────
# Required when MODEL_PROVIDER=opencode
OPENCODE_API_KEY=sk-...
# Model ID — no prefix, use IDs from: curl https://opencode.ai/zen/v1/models | jq '.data[].id'
# Available: claude-sonnet-4, claude-opus-4-1, gpt-5, gpt-5-codex, qwen3-coder, kimi-k2, ...
OPENCODE_MODEL=claude-sonnet-4

# ─── vLLM (only used when MODEL_PROVIDER=local) ──────────────────────────────
ENABLE_VLLM=1
MODEL_PATH=/opt/models/Qwen3-14B-AWQ
MODEL_REPO=Qwen/Qwen3-14B-AWQ
SERVED_MODEL_NAME=qwen3-14b

VLLM_HOST=127.0.0.1
VLLM_PORT=8000
VLLM_GPU_MEMORY_UTILIZATION=0.93
VLLM_MAX_MODEL_LEN=16384
VLLM_MAX_NUM_SEQS=64
VLLM_DTYPE=auto
VLLM_ENABLE_AUTO_TOOL_CHOICE=1
# Parser: qwen3_xml | hermes | lfm2
VLLM_TOOL_CALL_PARSER=qwen3_xml
# VLLM_CHAT_TEMPLATE=tool_use
# VLLM_TOOL_PARSER_PLUGIN=/app/vllm_lfm2_tool_parser.py

# ─── External model endpoint (alternative to MODEL_PROVIDER) ─────────────────
# Used when ENABLE_VLLM=0 and MODEL_PROVIDER=local (manual override)
# MODEL_BASE_URL=http://my-vllm-host:8000/v1

# ─── Workspace / project access ──────────────────────────────────────────────
# Path inside the container where Hermes looks for your project.
# Hermes gateway starts with this as its working directory.
WORKSPACE_PATH=/workspace/project

# Option A — Git clone on startup (works on RunPod with no network volume)
# Hermes will clone this repo into WORKSPACE_PATH before starting.
# GIT_REPO_URL=https://github.com/you/your-repo
# GIT_REPO_REF=main        # optional: branch, tag, or commit (defaults to repo default branch)
# GIT_TOKEN=ghp_...        # GitHub PAT for private repos — injected into the clone URL, never logged
#                          # Minimum required scope: Contents: Read-only (fine-grained PAT)
#                          # or repo (classic PAT)

# Option B — Network Volume (RunPod)
# Attach a RunPod Network Volume at pod creation — it mounts to /runpod-volume.
# Clone your repo there once: git clone ... /runpod-volume/project
# Then set: WORKSPACE_PATH=/runpod-volume/project

# Option C — Local volume mount (local Docker only, cannot be set in .env)
# docker run --env-file .env -v /your/project:/workspace/project -p 8642:8642 ...

# ─── Hermes gateway ──────────────────────────────────────────────────────────
HERMES_API_KEY=change-me-runpod
HERMES_API_HOST=0.0.0.0
HERMES_API_PORT=8642
MODEL_STARTUP_TIMEOUT=900

# ─── Hermes bootstrap ────────────────────────────────────────────────────────
HERMES_BOOTSTRAP_DEFAULTS=1
HERMES_BOOTSTRAP_SOUL=1
HERMES_BOOTSTRAP_SKILLS=1
# HERMES_SOUL_TEMPLATE_PATH=/app/defaults/soul/SOUL.safe.md
# HERMES_SKILLS_TEMPLATE_DIR=/app/defaults/skills
# HERMES_SOUL_FORCE=0
# HERMES_SKILLS_FORCE=0
